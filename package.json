{
  "name": "saas-packages",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Shared design system and packages for the SaaS product (polyrepo sibling).",
  "license": "MIT",
  "author": "Oscar Ospina",
  "engines": {
    "node": ">=22.12"
  },
  "workspaces": [
    "ui",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=@saas/ui --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build:tokens": "npm run build:tokens --workspace=@saas/ui",
    "check:tokens": "npm run check:tokens --workspace=@saas/ui",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
